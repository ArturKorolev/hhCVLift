{
  "manifest_version": 3,
  "name": "hhCVlift",
  "version": "1.0.0",
  "description": "Автоподнятие резюме на hh.ru",
  "permissions": ["storage", "alarms", "tabs", "scripting"],
  "host_permissions": [
    "*://*.hh.ru/*",
    "*://hh.ru/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "hhCVlift"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.hh.ru/applicant/resumes*",
        "*://hh.ru/applicant/resumes*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
